# ── Salt derivation secret ────────────────────────────────────────────────────
# Used to derive a deterministic salt per user (HMAC of Google sub + iss).
# Change this to a strong random string in production.
SALT_SECRET=change-me-to-a-strong-random-string

# ── ZK Proving Service ────────────────────────────────────────────────────────
# Dev endpoint (testnet): https://prover-dev.mystenlabs.com/v1
# Production endpoint requires authorization from Mysten Labs
ZK_PROVER_URL=https://prover-dev.mystenlabs.com/v1
